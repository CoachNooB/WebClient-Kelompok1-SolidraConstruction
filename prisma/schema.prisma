generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Locale {
  ID
  EN
}

enum UserRole {
  SUPER_ADMIN
  EDITOR
  REVIEWER
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum VacancyStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

enum ApplicationStatus {
  NEW
  REVIEWING
  SHORTLISTED
  REJECTED
  HIRED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum SectionType {
  HERO
  RICH_TEXT
  METRICS
  SERVICES
  PROJECTS
  TIMELINE
  VALUES
  LEADERSHIP
  CERTIFICATIONS
  FINANCIALS
  DOCUMENTS
  GOVERNANCE
  OFFICES
  CONTACT_FORM
  BENEFITS
  PROCESS
  VACANCIES
  CTA
}

enum MediaVisibility {
  PUBLIC
  PRIVATE
}

enum NavigationLocation {
  HEADER
  FOOTER
}

model User {
  id             String           @id @default(cuid())
  name           String
  email          String           @unique
  emailVerified  Boolean          @default(false)
  image          String?
  role           UserRole         @default(EDITOR)
  active         Boolean          @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  sessions       Session[]
  accounts       Account[]
  publishedPages Page[]           @relation("PagePublisher")
  media          MediaAsset[]
  notes          SubmissionNote[]
  auditLogs      AuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Page {
  id           String            @id @default(cuid())
  key          String            @unique
  slug         String            @unique
  status       ContentStatus     @default(DRAFT)
  publishedAt  DateTime?
  publisherId  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  publisher    User?             @relation("PagePublisher", fields: [publisherId], references: [id])
  translations PageTranslation[]
  sections     PageSection[]
}

model PageTranslation {
  id             String  @id @default(cuid())
  pageId         String
  locale         Locale
  title          String
  description    String
  seoTitle       String?
  seoDescription String?
  page           Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
}

model PageSection {
  id           String                   @id @default(cuid())
  pageId       String
  type         SectionType
  order        Int
  visible      Boolean                  @default(true)
  config       Json?
  mediaId      String?
  page         Page                     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  media        MediaAsset?              @relation(fields: [mediaId], references: [id], onDelete: Restrict)
  translations PageSectionTranslation[]

  @@unique([pageId, order])
}

model PageSectionTranslation {
  id        String      @id @default(cuid())
  sectionId String
  locale    Locale
  heading   String?
  body      String?
  ctaLabel  String?
  ctaUrl    String?
  section   PageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, locale])
}

model MediaAsset {
  id          String          @id @default(cuid())
  storagePath String          @unique
  fileName    String
  mimeType    String
  size        Int
  width       Int?
  height      Int?
  altId       String?
  altEn       String?
  visibility  MediaVisibility @default(PUBLIC)
  ownerId     String
  createdAt   DateTime        @default(now())
  owner       User            @relation(fields: [ownerId], references: [id])
  sections    PageSection[]
  projects    Project[]
}

model NavigationItem {
  id           String                      @id @default(cuid())
  location     NavigationLocation
  order        Int
  url          String
  external     Boolean                     @default(false)
  visible      Boolean                     @default(true)
  parentId     String?
  parent       NavigationItem?             @relation("NavigationTree", fields: [parentId], references: [id])
  children     NavigationItem[]            @relation("NavigationTree")
  translations NavigationItemTranslation[]

  @@unique([location, order, parentId])
}

model NavigationItemTranslation {
  id     String         @id @default(cuid())
  itemId String
  locale Locale
  label  String
  item   NavigationItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, locale])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model FooterGroup {
  id           String                   @id @default(cuid())
  order        Int                      @unique
  visible      Boolean                  @default(true)
  translations FooterGroupTranslation[]
  links        FooterLink[]
}

model FooterGroupTranslation {
  id      String      @id @default(cuid())
  groupId String
  locale  Locale
  title   String
  group   FooterGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, locale])
}

model FooterLink {
  id           String                  @id @default(cuid())
  groupId      String
  order        Int
  url          String
  external     Boolean                 @default(false)
  visible      Boolean                 @default(true)
  group        FooterGroup             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  translations FooterLinkTranslation[]

  @@unique([groupId, order])
}

model FooterLinkTranslation {
  id     String     @id @default(cuid())
  linkId String
  locale Locale
  label  String
  link   FooterLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@unique([linkId, locale])
}

model Project {
  id           String               @id @default(cuid())
  slug         String               @unique
  location     String
  completedAt  DateTime?
  featured     Boolean              @default(false)
  order        Int                  @default(0)
  mediaId      String?
  media        MediaAsset?          @relation(fields: [mediaId], references: [id], onDelete: Restrict)
  translations ProjectTranslation[]
}

model ProjectTranslation {
  id          String  @id @default(cuid())
  projectId   String
  locale      Locale
  title       String
  description String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
}

model Office {
  id           String              @id @default(cuid())
  key          String              @unique
  address      String
  city         String
  phone        String?
  email        String?
  latitude     Decimal?            @db.Decimal(10, 7)
  longitude    Decimal?            @db.Decimal(10, 7)
  hours        Json?
  order        Int                 @default(0)
  translations OfficeTranslation[]
}

model OfficeTranslation {
  id           String  @id @default(cuid())
  officeId     String
  locale       Locale
  name         String
  addressLabel String?
  office       Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@unique([officeId, locale])
}

model InvestorDocument {
  id           String                        @id @default(cuid())
  storagePath  String
  year         Int
  category     String
  mimeType     String                        @default("application/pdf")
  size         Int
  publishedAt  DateTime?
  status       ContentStatus                 @default(DRAFT)
  translations InvestorDocumentTranslation[]

  @@index([status, year])
}

model InvestorDocumentTranslation {
  id          String           @id @default(cuid())
  documentId  String
  locale      Locale
  title       String
  description String?
  document    InvestorDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, locale])
}

model Vacancy {
  id             String               @id @default(cuid())
  department     String
  location       String
  employmentType EmploymentType
  closingDate    DateTime
  status         VacancyStatus        @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  translations   VacancyTranslation[]
  applications   CareerApplication[]

  @@index([status, closingDate])
}

model VacancyTranslation {
  id               String  @id @default(cuid())
  vacancyId        String
  locale           Locale
  slug             String
  title            String
  summary          String
  responsibilities Json
  requirements     Json
  vacancy          Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  @@unique([vacancyId, locale])
  @@unique([locale, slug])
}

model ContactMessage {
  id             String           @id @default(cuid())
  name           String
  email          String
  phone          String?
  company        String?
  subject        String
  message        String
  locale         Locale
  status         ContactStatus    @default(NEW)
  idempotencyKey String           @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  notes          SubmissionNote[]

  @@index([status, createdAt])
}

model CareerApplication {
  id             String            @id @default(cuid())
  vacancyId      String
  name           String
  email          String
  phone          String
  coverLetter    String
  cvStoragePath  String            @unique
  status         ApplicationStatus @default(NEW)
  idempotencyKey String            @unique
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  vacancy        Vacancy           @relation(fields: [vacancyId], references: [id], onDelete: Restrict)
  notes          SubmissionNote[]

  @@index([vacancyId, status])
}

model SubmissionNote {
  id                  String             @id @default(cuid())
  body                String
  authorId            String
  contactMessageId    String?
  careerApplicationId String?
  createdAt           DateTime           @default(now())
  author              User               @relation(fields: [authorId], references: [id])
  contactMessage      ContactMessage?    @relation(fields: [contactMessageId], references: [id], onDelete: Cascade)
  careerApplication   CareerApplication? @relation(fields: [careerApplicationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User     @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([entity, entityId])
  @@index([createdAt])
}
